# --- Required secrets -------------------------------------------------------
# Discord bot token (Developer Portal -> your app -> Bot -> Reset Token).
DISCORD_TOKEN=your-discord-bot-token-here
# Anthropic API key (console.anthropic.com). Billing is in USD.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Optional configuration (sensible defaults shown) -----------------------
# Model used to PARSE requests (security is enforced in code regardless).
# Swap to claude-haiku-4-5-20251001 to cut cost.
ANTHROPIC_MODEL=claude-sonnet-5
MAX_TOKENS=2048
MAX_AGENT_ITERATIONS=8

# Per-user write-action rate limit.
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60

# Ask for a single confirmation when one AI turn proposes at least this many writes.
BULK_CONFIRM_THRESHOLD=3

# Punitive tools (ban/kick/timeout). Even when enabled they REQUIRE a typed
# CONFIRM naming the exact target; they are never run straight off an LLM parse.
ENABLE_PUNITIVE=true

# --- Conversation context ---------------------------------------------------
# On each mention the bot can gather focused context so references like "ban
# them" (as a reply) or "undo what you just did" resolve. Author names/IDs are
# trusted metadata; message bodies stay untrusted (permissions are still
# enforced in code). Set CONTEXT_ENABLED=false to send only the raw message.
CONTEXT_ENABLED=true
# Include the message the requester is replying to (the strongest signal).
CONTEXT_INCLUDE_REPLIES=true
# How many recent channel messages to include for background (0 disables them).
CONTEXT_HISTORY_LIMIT=5
# Per-message body cap (characters) so long messages can't blow the token budget.
CONTEXT_MAX_MESSAGE_CHARS=400

# SQLite database for the audit log + per-guild settings.
DB_PATH=moderator.db

# --- Web control hub ---------------------------------------------------------
# Browser twin of the TUI, run with `./setup.sh --web`. It binds to localhost
# only; expose it at https://dcgsl.duckdns.org with `sudo ./deploy/install-web.sh`
# (auto-configures nginx, a Let's Encrypt certificate, and a systemd service).
WEB_HOST=127.0.0.1
WEB_PORT=8134
WEB_DOMAIN=dcgsl.duckdns.org
# Admin password as an scrypt hash — set with: python run.py --set-web-password
WEB_PASSWORD_HASH=
# Session-cookie signing secret; auto-generated on first web launch if empty.
WEB_SESSION_SECRET=
# How long a browser login lasts.
WEB_SESSION_HOURS=12

# --- Auto-update (managed from the TUI's Maintenance tab) -------------------
# When AUTO_UPDATE is on, the hub periodically checks the git upstream and, if
# there are new commits, pulls (fast-forward only) and reinstalls dependencies.
# If AUTO_RESTART is also on, it restarts the bot afterwards to apply the update.
AUTO_UPDATE=false
AUTO_UPDATE_INTERVAL=30
AUTO_RESTART=false
